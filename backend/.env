PRICE_EVENING=15
PRICE_NIGHT=12
POINTS_PER_POUND=0.1
COUPON_POINTS_THRESHOLD=100
COUPON_DISCOUNT_PERCENT=20

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:3000
